# for example ["playwright"] for browser QA or ["openaiDeveloperDocs"] for doc lookup.
run_mcps = []

[agents.codex]
model = "gpt-5.4"
# profile = "forge-long"

[agents.claude]
model = "claude-opus-4-6"
effort = "high"
```

